---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import DraftScaffold from '../components/DraftScaffold.astro';
import Tradeoffs from '../components/Tradeoffs.astro';
import Related from '../components/Related.astro';
import QuizBlock from '../components/QuizBlock.astro';
import Pager from '../components/Pager.astro';
import Comments from '../components/Comments.astro';
import LikeButton from '../components/islands/LikeButton.tsx';
import { readingTime } from '../lib/reading-time';
import { TRACKS } from '../lib/consts';

const {
  entry,
  collection = 'qiraa',
  base = '/qiraa',
  sectionTitle = 'القراءة والكتابة',
  sectionHref = '/qiraa/',
  relatedHeading = 'دروس ذات صلة',
  topicLabel = 'القراءة والكتابة',
} = Astro.props;
const d = entry.data;
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const catLabel = cap(d.category.replace(/-/g, ' '));
const trackMeta = TRACKS.find(t => `/${t.route}` === base);
const sectionTitle_en = trackMeta?.title_en ?? sectionTitle;

// Per-page Arabic content (ordered to match the runtime block collector).
const contentModules = import.meta.glob('../i18n/content/*.json', { eager: true });
const contentAr = (contentModules[`../i18n/content/${entry.id}.json`] as any)?.default ?? [];

// The track's full slug list, so marking a page learned can detect milestone
// crossings (25/50/75/100%) right at the moment they happen.
const trackEntries = await getCollection(collection);
const trackInfo = {
  name: sectionTitle,
  slugs: [...trackEntries].sort((a, b) => a.data.order - b.data.order).map((e) => e.id),
};
---
<BaseLayout title={d.title} description={d.intent}>
  <article>
    <nav class="dp-breadcrumb dp-kicker">
      <a href={sectionHref}>
        <span data-lang-block="ar">{sectionTitle}</span>
        <span data-lang-block="en">{sectionTitle_en}</span>
      </a> › <span>{catLabel}</span> › <span>
        <span data-lang-block="ar">{d.title}</span>
        <span data-lang-block="en">{d.title_en ?? d.title}</span>
      </span>
    </nav>

    <PageHeader data={d} slug={entry.id} topicLabel={topicLabel} minutes={readingTime(entry.body)} />

    <div class="dp-article">
      <div class="dp-article__body dp-prose">
        <slot />
        {d.status !== 'ready' && <DraftScaffold data={d} />}
        <Tradeoffs data={d} />
        <Related related={d.related} collection={collection} base={base} heading={relatedHeading} />
        {d.quiz.length > 0 && <QuizBlock quiz={d.quiz} />}
        <Pager slug={entry.id} collection={collection} base={base} />
        <Comments />
      </div>

      <aside class="dp-article__toc" aria-label="في هذه الصفحة">
        <div class="dp-article__toc-inner">
          <p class="dp-toc-title" data-i18n="pagelayout.progress">تقدّمك</p>
          <div class="dp-like-dock">
            <LikeButton client:visible page={`${base}/${entry.id}`} />
          </div>
          <p class="dp-views" data-dp-views={`${base}/${entry.id}`} hidden>
            <svg class="dp-views__icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            <strong data-dp-views-num>—</strong>
            <span data-i18n="pagelayout.views">مشاهدة</span>
          </p>
          <button class="dp-btn" data-dp-learn={entry.id} aria-pressed="false">
            <span data-dp-learn-label data-i18n="pagelayout.markLearned">علِّم كمتعلَّم</span>
          </button>
          <p class="dp-toc-title" style="margin-top:1.5rem" data-i18n="pagelayout.toc">في هذه الصفحة</p>
          <ul class="dp-toc" data-dp-toc></ul>
        </div>
      </aside>
    </div>
  </article>

  <script type="application/json" id="dp-content-ar" set:html={JSON.stringify(contentAr)}></script>
  <script type="application/json" id="dp-track-info" set:html={JSON.stringify(trackInfo).replace(/</g, '\\u003c')}></script>
  <script>import '../scripts/mermaid.js';</script>
</BaseLayout>
