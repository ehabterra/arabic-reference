---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { TRACKS, SITE_DESC, SITE_DESC_EN } from '../lib/consts';

const qiraa = await getCollection('qiraa');
const nahw = await getCollection('nahw');
const sarf = await getCollection('sarf');
const balagha = await getCollection('balagha');
const tajwid = await getCollection('tajwid');
const khat = await getCollection('khat');
const quranArabic = await getCollection('quranArabic');

// unified progress across every page in the reference
const allSlugs = [...qiraa, ...nahw, ...sarf, ...balagha, ...tajwid, ...khat, ...quranArabic].map((p) => p.id).join(',');

// Ordered per-track manifest for the resume card
const trackList = [
  { base: '/qiraa', name: 'القراءة والكتابة', entries: qiraa },
  { base: '/nahw', name: 'النحو', entries: nahw },
  { base: '/sarf', name: 'الصرف', entries: sarf },
  { base: '/balagha', name: 'البلاغة', entries: balagha },
  { base: '/tajwid', name: 'التجويد', entries: tajwid },
  { base: '/khat', name: 'الخط العربي', entries: khat },
  { base: '/arabic-via-quran', name: 'العربية عبر القرآن', entries: quranArabic },
];
const resumeManifest = trackList.map((t) => ({
  base: t.base,
  name: t.name,
  pages: [...t.entries]
    .sort((a, b) => a.data.order - b.data.order)
    .map((e) => ({ id: e.id, title: e.data.title, ...(e.data.quiz?.length ? { q: 1 } : {}) })),
}));

const trackIcons: Record<string, string> = {
  qiraa: '📖',
  nahw: '✍️',
  sarf: '⚖️',
  balagha: '🌸',
  tajwid: '🗣️',
  khat: '🖋️',
  quranArabic: '📿',
};
---
<BaseLayout>
  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="home.eyebrow">مرجع تفاعلي للغة العربية</p>
    <h1 data-i18n="home.h1">المرجع العربي</h1>
    <p class="dp-hero__lede">
      <span data-lang-block="ar">{SITE_DESC}</span>
      <span data-lang-block="en">{SITE_DESC_EN}</span>
    </p>
  </header>

  <section class="dp-resume" data-dp-resume hidden>
    <div class="dp-resume__info">
      <p class="dp-resume__kicker" data-i18n="home.resumeKicker">واصل من حيث توقّفت</p>
      <h2 class="dp-resume__title" data-dp-resume-title></h2>
      <p class="dp-resume__meta">
        <span data-dp-resume-track></span> · <span data-dp-resume-count></span>
        <span data-i18n="home.learnedSuffix">تعلّمت</span>
      </p>
    </div>
    <div class="dp-resume__actions">
      <a class="dp-btn dp-btn--primary" data-dp-resume-link><span data-i18n="home.resume">واصل</span> →</a>
      <a class="dp-btn dp-btn--ghost" data-dp-resume-next hidden>
        <span data-i18n="home.nextUp">التالي</span>: <span data-dp-resume-next-title></span>
      </a>
    </div>
  </section>
  <section class="dp-resume dp-resume--review" data-dp-review-card hidden>
    <div class="dp-resume__info">
      <p class="dp-resume__kicker" data-i18n="home.reviewKicker">المراجعة اليومية</p>
      <h2 class="dp-resume__title">
        <span data-dp-review-count>0</span> <span data-i18n="home.reviewDue">صفحات للمراجعة السريعة</span>
      </h2>
      <p class="dp-resume__meta" data-i18n="home.reviewNote">بضع دقائق من الإجابة من الذاكرة تُرسّخ المعلومة للأبد.</p>
    </div>
    <div class="dp-resume__actions">
      <a class="dp-btn dp-btn--primary" href="/review/"><span data-i18n="home.reviewStart">ابدأ المراجعة</span> →</a>
    </div>
  </section>
  <script type="application/json" id="dp-resume-manifest" set:html={JSON.stringify(resumeManifest).replace(/</g, '\\u003c')}></script>

  <div class="dp-overall">
    <div class="dp-overall__top">
      <strong data-i18n="home.progressTitle">تقدُّمك الإجمالي</strong>
      <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-reset data-i18n="home.reset">إعادة ضبط</button>
    </div>
    <div class="dp-progress" data-dp-progress data-slugs={allSlugs}>
      <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
      <span class="dp-progress__label"></span>
    </div>
    <p class="dp-kicker" style="margin:.7rem 0 0;" data-i18n="home.progressNote">
      يُتابَع عبر كل المسارات — علِّم أي درس بـ"تعلّمت" وتقدّم الشريط. محفوظ في متصفّحك.
    </p>
  </div>

  <h2 class="dp-section-head" style="border:0;margin-top:2.4rem;" data-i18n="home.chooseTrack">اختر مساراً</h2>
  <div class="dp-topics">
    {TRACKS.map((track) => (
      <a class="dp-topic" data-cat={track.categories[0]?.key} href={`/${track.route}/`}>
        <div class="dp-topic__icon">{trackIcons[track.key] ?? '📚'}</div>
        <h3>
          <span data-lang-block="ar">{track.title}</span>
          <span data-lang-block="en">{track.title_en ?? track.title}</span>
        </h3>
        <p>
          <span data-lang-block="ar">{track.blurb}</span>
          <span data-lang-block="en">{track.blurb_en ?? track.blurb}</span>
        </p>
        <span class="dp-topic__stat">{track.categories.length} <span data-i18n="home.track.sections">أقسام</span></span>
        <span class="dp-topic__go" data-i18n="home.track.enter">ادخل →</span>
      </a>
    ))}
  </div>

  <section data-dp-toplikes hidden>
    <h2 class="dp-section-head" style="border:0;margin-top:2.6rem;" data-i18n="home.topLikes">أكثر الصفحات إعجاباً</h2>
    <div class="dp-toplikes" data-dp-toplikes-grid></div>
  </section>

  <section data-dp-mylikes hidden>
    <h2 class="dp-section-head" style="border:0;margin-top:2.6rem;" data-i18n="home.myLikes">صفحاتي المفضّلة</h2>
    <div class="dp-toplikes" data-dp-mylikes-grid></div>
  </section>

  <h2 class="dp-section-head" style="border:0;margin-top:2.8rem;" data-i18n="home.howItWorks">كيف يعمل المرجع</h2>
  <div class="dp-features">
    <div class="dp-feature">
      <div class="dp-feature__icon">📊</div>
      <h3>
        <span data-lang-block="ar">مخططات توضيحية</span>
        <span data-lang-block="en" data-i18n="home.feature.diagrams.title">Visual diagrams</span>
      </h3>
      <p>
        <span data-lang-block="ar">مخططات مرموز تجعل العلاقات واضحة قبل أن تقرأ سطراً واحداً.</span>
        <span data-lang-block="en" data-i18n="home.feature.diagrams.body">Structured charts make relationships clear before you read a single line.</span>
      </p>
    </div>
    <div class="dp-feature">
      <div class="dp-feature__icon">📝</div>
      <h3>
        <span data-lang-block="ar">أمثلة تطبيقية</span>
        <span data-lang-block="en" data-i18n="home.feature.examples.title">Applied examples</span>
      </h3>
      <p>
        <span data-lang-block="ar">كل مفهوم مدعوم بأمثلة أصيلة من اللغة العربية الفصيحة.</span>
        <span data-lang-block="en" data-i18n="home.feature.examples.body">Every concept backed by authentic classical Arabic examples.</span>
      </p>
    </div>
    <div class="dp-feature">
      <div class="dp-feature__icon">🧠</div>
      <h3>
        <span data-lang-block="ar">مصنوع للحفظ</span>
        <span data-lang-block="en" data-i18n="home.feature.memory.title">Made for retention</span>
      </h3>
      <p>
        <span data-lang-block="ar">اختبار في كل درس وتتبُّع للتقدم يحوّل القراءة السلبية إلى رحلة تُكملها.</span>
        <span data-lang-block="en" data-i18n="home.feature.memory.body">A quiz per lesson and progress tracking turns passive reading into a journey you complete.</span>
      </p>
    </div>
    <div class="dp-feature">
      <div class="dp-feature__icon">📚</div>
      <h3>
        <span data-lang-block="ar">مصادر موثَّقة</span>
        <span data-lang-block="en" data-i18n="home.feature.sources.title">Cited sources</span>
      </h3>
      <p>
        <span data-lang-block="ar">كل قاعدة مرتبطة بمصادرها من كتب النحو والبلاغة والتجويد المعتمدة.</span>
        <span data-lang-block="en" data-i18n="home.feature.sources.body">Every rule linked to its sources in accredited nahw, balagha, and tajwid texts.</span>
      </p>
    </div>
  </div>
</BaseLayout>
