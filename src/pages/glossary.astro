---
import BaseLayout from '../layouts/BaseLayout.astro';

// Bilingual glossary of the Arabic language sciences. Each term carries an
// Arabic term + definition (base) and an English term + definition (overlay);
// the active one shows via the site-wide [data-lang-block] toggle.
interface Term { ar: string; en: string; defAr: string; defEn: string }
const groups: { ar: string; en: string; terms: Term[] }[] = [
  {
    ar: 'النحو', en: 'Grammar (Naḥw)',
    terms: [
      { ar: 'الإعراب', en: 'Iʿrāb — inflection', defAr: 'تغيُّر آخر الكلمة بتغيُّر العوامل الداخلة عليها رفعًا أو نصبًا أو جرًّا أو جزمًا.', defEn: 'The change in a word’s ending according to its grammatical role: nominative, accusative, genitive, or jussive.' },
      { ar: 'البناء', en: 'Bināʾ — indeclinability', defAr: 'لزومُ آخر الكلمة حالةً واحدة لا تتغيّر مهما تغيّر العامل.', defEn: 'A word’s ending staying fixed regardless of its grammatical role.' },
      { ar: 'الفاعل', en: 'Al-Fāʿil — the subject', defAr: 'اسمٌ مرفوع يدلّ على من فعل الفعل.', defEn: 'The nominative noun naming the doer of the action.' },
      { ar: 'المفعول به', en: 'Al-Mafʿūl bih — the object', defAr: 'اسمٌ منصوب وقع عليه فعلُ الفاعل.', defEn: 'The accusative noun on which the action falls.' },
      { ar: 'المبتدأ والخبر', en: 'Mubtadaʾ & Khabar', defAr: 'ركنا الجملة الاسمية: المبتدأ المُحدَّث عنه، والخبر ما يُكمِّل معناه.', defEn: 'The two pillars of a nominal sentence: the subject and what predicates it.' },
      { ar: 'المرفوعات', en: 'Nominatives', defAr: 'الأسماء التي حكمها الرفع: الفاعل، نائبه، المبتدأ، الخبر…', defEn: 'Nouns that take the nominative case.' },
      { ar: 'المنصوبات', en: 'Accusatives', defAr: 'الأسماء التي حكمها النصب: المفاعيل، الحال، التمييز، الاستثناء…', defEn: 'Nouns that take the accusative case.' },
      { ar: 'المجرورات', en: 'Genitives', defAr: 'ما يُجرّ بحرف جرٍّ أو بالإضافة.', defEn: 'Nouns made genitive by a preposition or by annexation.' },
    ],
  },
  {
    ar: 'الصرف', en: 'Morphology (Ṣarf)',
    terms: [
      { ar: 'الميزان الصرفي', en: 'Al-Mīzān al-Ṣarfī', defAr: 'مقياسٌ يُوزَن به بناء الكلمة على الحروف «ف ع ل».', defEn: 'The root-template (f-ʿ-l) used to weigh a word’s pattern.' },
      { ar: 'المجرّد والمزيد', en: 'Bare & Augmented', defAr: 'المجرّد حروفه كلُّها أصلية، والمزيد فيه حروف زائدة على الأصل.', defEn: 'A bare verb has only root letters; an augmented verb adds letters to the root.' },
      { ar: 'المشتقّات', en: 'Derivatives', defAr: 'أسماء مأخوذة من المصدر: اسم الفاعل، اسم المفعول، الصفة المشبَّهة…', defEn: 'Nouns derived from the verbal noun (participles, etc.).' },
      { ar: 'اسم الفاعل', en: 'Active participle', defAr: 'صفةٌ تدلّ على من قام بالفعل، كـ«كاتب».', defEn: 'A form naming the one performing the action (e.g. kātib, “writer”).' },
      { ar: 'اسم المفعول', en: 'Passive participle', defAr: 'صفةٌ تدلّ على من وقع عليه الفعل، كـ«مكتوب».', defEn: 'A form naming the one the action falls upon (e.g. maktūb, “written”).' },
      { ar: 'المصدر', en: 'Maṣdar — verbal noun', defAr: 'اسمٌ يدلّ على الحدث مجرَّدًا من الزمن، كـ«كتابة».', defEn: 'A noun naming the action itself, with no time (e.g. kitāba, “writing”).' },
      { ar: 'الإعلال', en: 'Iʿlāl', defAr: 'تغييرٌ يلحق حرف العلّة (و/ا/ي) قلبًا أو حذفًا أو تسكينًا.', defEn: 'A change affecting a weak letter (w/ā/y) by substitution, deletion, or quiescence.' },
      { ar: 'الإدغام', en: 'Idghām (morphology)', defAr: 'إدخال حرفٍ ساكن في مِثله المتحرّك فيصيران حرفًا مشدَّدًا.', defEn: 'Merging two identical letters into one doubled (shadda) letter.' },
    ],
  },
  {
    ar: 'البلاغة', en: 'Rhetoric (Balāgha)',
    terms: [
      { ar: 'البلاغة', en: 'Balāgha', defAr: 'مطابقةُ الكلام لمقتضى الحال مع فصاحته.', defEn: 'Eloquence: fitting speech to its context while remaining clear and correct.' },
      { ar: 'التشبيه', en: 'Tashbīh — simile', defAr: 'عقدُ مشابهةٍ بين شيئين بأداةٍ مذكورة أو مقدَّرة.', defEn: 'Likening one thing to another using a comparison particle.' },
      { ar: 'الاستعارة', en: 'Istiʿāra — metaphor', defAr: 'تشبيهٌ حُذف أحدُ طرفيه؛ مجازٌ علاقته المشابهة.', defEn: 'A metaphor: a simile with one of its two sides omitted.' },
      { ar: 'المجاز', en: 'Majāz', defAr: 'استعمال اللفظ في غير معناه الأصلي لعلاقةٍ مع قرينةٍ مانعة.', defEn: 'Figurative use of a word for a related sense, with a clue barring the literal one.' },
      { ar: 'الكناية', en: 'Kināya — metonymy', defAr: 'لفظٌ أُريد به لازمُ معناه مع جواز إرادة الأصل.', defEn: 'A word meant for an implied associate of its literal sense.' },
      { ar: 'القصر', en: 'Qaṣr — restriction', defAr: 'تخصيصُ شيءٍ بشيءٍ بطريقٍ مخصوص.', defEn: 'Confining one thing to another by a specific device.' },
      { ar: 'الطباق', en: 'Ṭibāq — antithesis', defAr: 'الجمعُ بين الشيء وضدِّه في الكلام.', defEn: 'Pairing a thing with its opposite.' },
      { ar: 'الجناس', en: 'Jinās — paronomasia', defAr: 'تشابهُ لفظين في النطق واختلافهما في المعنى.', defEn: 'Two words alike in sound but different in meaning.' },
    ],
  },
  {
    ar: 'التجويد', en: 'Recitation (Tajwīd)',
    terms: [
      { ar: 'التجويد', en: 'Tajwīd', defAr: 'إعطاءُ كلِّ حرفٍ حقَّه ومستحقَّه في التلاوة.', defEn: 'Giving each letter its due articulation and qualities in recitation.' },
      { ar: 'المخرج', en: 'Makhraj', defAr: 'موضعُ خروج الحرف من الفم أو الحلق أو الخيشوم.', defEn: 'The point from which a letter is articulated.' },
      { ar: 'الصفة', en: 'Ṣifa', defAr: 'كيفيةٌ تُميِّز الحرف، كالهمس والجهر والشدّة والرخاوة.', defEn: 'A quality distinguishing a letter (whispered/voiced, etc.).' },
      { ar: 'الإظهار', en: 'Iẓhār', defAr: 'إخراجُ النون الساكنة والتنوين واضحًا عند حروف الحلق الستة.', defEn: 'Pronouncing a quiescent nūn/tanwīn clearly before the six throat letters.' },
      { ar: 'الإدغام', en: 'Idghām (recitation)', defAr: 'إدخالُ النون الساكنة في الحرف التالي من حروف «يرملون».', defEn: 'Merging a quiescent nūn into a following yarmalūn letter.' },
      { ar: 'الإقلاب', en: 'Iqlāb', defAr: 'قلبُ النون الساكنة والتنوين ميمًا مخفاةً عند الباء.', defEn: 'Converting a quiescent nūn/tanwīn into a hidden mīm before bāʾ.' },
      { ar: 'الإخفاء', en: 'Ikhfāʾ', defAr: 'نطقُ النون بحالةٍ بين الإظهار والإدغام مع الغنّة.', defEn: 'Pronouncing the nūn midway between iẓhār and idghām, with nasalization.' },
      { ar: 'المدّ', en: 'Madd', defAr: 'إطالةُ الصوت بحرفٍ من حروف المدّ (ا و ي).', defEn: 'Prolonging the sound on a madd letter (ā/w/y).' },
      { ar: 'الغنّة', en: 'Ghunna', defAr: 'صوتٌ يخرج من الخيشوم يصاحب النون والميم.', defEn: 'The nasal sound accompanying nūn and mīm.' },
      { ar: 'القلقلة', en: 'Qalqala', defAr: 'اضطرابُ الحرف الساكن عند النطق في حروف «قطب جد».', defEn: 'The slight “bounce” of certain quiescent letters (q ṭ b j d).' },
    ],
  },
  {
    ar: 'الخط العربي', en: 'Calligraphy (Khaṭṭ)',
    terms: [
      { ar: 'الخط', en: 'Khaṭṭ', defAr: 'فنُّ الكتابة العربية الجميلة وفق قواعدَ وأوزان.', defEn: 'The art of beautiful Arabic writing by set rules and proportions.' },
      { ar: 'النسخ', en: 'Naskh', defAr: 'خطٌّ متوازنٌ واضح؛ خطُّ المصاحف والطباعة.', defEn: 'A balanced, legible script — of muṣḥafs and print.' },
      { ar: 'الرقعة', en: 'Ruqʿa', defAr: 'خطٌّ سريعٌ مختصر للكتابة اليومية.', defEn: 'A quick, compact everyday handwriting script.' },
      { ar: 'الثلث', en: 'Thuluth', defAr: 'خطٌّ زخرفيٌّ رشيق يكثر في العناوين والزخارف.', defEn: 'A flowing decorative script common in titles and ornament.' },
      { ar: 'الديواني', en: 'Dīwānī', defAr: 'خطٌّ منحنٍ متشابك نشأ في الدواوين العثمانية.', defEn: 'A curved, interlaced script that arose in the Ottoman chanceries.' },
      { ar: 'قياس النقاط', en: 'Dot measurement', defAr: 'وحدةُ قياسٍ تُضبَط بها أبعادُ الحروف بنقاط القلم.', defEn: 'Measuring a letter’s proportions in units of the pen’s nib-dots.' },
    ],
  },
  {
    ar: 'القراءة والكتابة', en: 'Reading & Writing',
    terms: [
      { ar: 'الحرف', en: 'Ḥarf — letter', defAr: 'رمزٌ صوتيٌّ من حروف الهجاء، وعدّتها ثمانية وعشرون.', defEn: 'A letter of the alphabet (28 in all).' },
      { ar: 'الحركة', en: 'Ḥaraka — short vowel', defAr: 'علامةُ الصوت القصير: الفتحة والضمّة والكسرة.', defEn: 'A short-vowel mark: fatḥa, ḍamma, kasra.' },
      { ar: 'السكون', en: 'Sukūn', defAr: 'علامةُ خلوِّ الحرف من الحركة.', defEn: 'The mark of a vowelless (resting) consonant.' },
      { ar: 'الشدّة', en: 'Shadda', defAr: 'علامةُ تضعيف الحرف ونطقِه مرّتين.', defEn: 'The mark doubling a consonant.' },
      { ar: 'التنوين', en: 'Tanwīn — nunation', defAr: 'نونٌ ساكنة زائدة في آخر الاسم (ـٌ ـً ـٍ).', defEn: 'An extra n-sound at the end of a noun (-un/-an/-in).' },
      { ar: 'المدّ', en: 'Madd (reading)', defAr: 'إطالةُ الحرف بألفٍ أو واوٍ أو ياءٍ ساكنة تجانس الحركة قبلها.', defEn: 'Lengthening a vowel with a matching ā/w/y.' },
      { ar: 'المقطع', en: 'Syllable', defAr: 'وحدةُ نطقٍ مكوّنة من حرفٍ وحركةٍ فأكثر.', defEn: 'A unit of pronunciation: a consonant plus a vowel.' },
    ],
  },
];
---
<BaseLayout title="المسرد" description="مصطلحات أساسية عبر علوم اللغة العربية، مع تعريفات موجزة.">
  <nav class="dp-breadcrumb dp-kicker">
    <a href="/"><span data-i18n="nav.home">تعلم العربية</span></a> › <span data-i18n="glossary.h1">المسرد</span>
  </nav>

  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="glossary.eyebrow">مرجع</p>
    <h1 data-i18n="glossary.h1">المسرد</h1>
    <p class="dp-hero__lede" data-i18n-html="glossary.lede">
      مصطلحاتٌ أساسية عبر علوم اللغة العربية، مع تعريفاتٍ موجزة.
    </p>
  </header>

  {groups.map((g) => (
    <section class="dp-gloss-sec">
      <h2 class="dp-section-head">
        <span data-lang-block="ar">{g.ar}</span><span data-lang-block="en">{g.en}</span>
      </h2>
      <dl class="dp-gloss">
        {g.terms.map((term) => (
          <div class="dp-gloss__item">
            <dt class="dp-gloss__term">
              <span data-lang-block="ar">{term.ar}</span><span data-lang-block="en">{term.en}</span>
            </dt>
            <dd class="dp-gloss__def">
              <span data-lang-block="ar" set:html={term.defAr} /><span data-lang-block="en" set:html={term.defEn} />
            </dd>
          </div>
        ))}
      </dl>
    </section>
  ))}
</BaseLayout>
