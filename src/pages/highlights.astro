---
import BaseLayout from '../layouts/BaseLayout.astro';
// The list itself is rendered client-side from localStorage by highlights.js
// (it's per-visitor data) — this page is just the shell, empty state, and the
// "clear all" control.
---
<BaseLayout title="التظليلات" description="كل مقطع ظلّلته عبر تعلم العربية، مجموعٌ في مكان واحد ومرتبطٌ بموضعه — دفتر قراءتك الخاص، محفوظ في هذا المتصفح ومزامَن عبر أجهزتك.">
  <nav class="dp-breadcrumb dp-kicker">
    <a href="/"><span data-i18n="nav.home">تعلم العربية</span></a> › <span data-i18n="hl.h1">التظليلات</span>
  </nav>

  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="hl.eyebrow">دفتر ملاحظاتك</p>
    <h1 data-i18n="hl.h1">التظليلات</h1>
    <p class="dp-hero__lede" data-i18n-html="hl.lede">
      حدِّد أي نص أثناء القراءة واضغط <strong>تظليل</strong> — يُحفظ هنا ويُعلَّم في الصفحة. كل شيء يبقى في هذا المتصفح (ويُزامَن عبر أجهزتك إن أضفت بريدًا)، فيصبح هذا مرجعك الخاص المتنامي لأهم ما قرأت.
    </p>
  </header>

  <div class="dp-highlights" data-dp-highlights>
    <div class="dp-highlights__bar">
      <p class="dp-kicker">
        <strong data-dp-highlights-count>0</strong>
        <span data-i18n="hl.saved">تظليلات محفوظة</span>
      </p>
      <div class="dp-highlights__controls">
        <label class="dp-hl-optout" title="الأرقام مجهولة — يُشارَك عدد القرّاء لكل فقرة فقط، لا نصّك ولا ملاحظاتك ولا هويّتك.">
          <input type="checkbox" data-dp-hl-stats-optout checked />
          <span data-i18n="hl.statsShare">مشاركة إحصاءات التظليل المجهولة</span>
        </label>
        <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-highlights-clear hidden data-i18n="hl.clear">
          مسح الكل
        </button>
      </div>
    </div>

    <div class="dp-highlights__empty" data-dp-highlights-empty hidden>
      <p class="dp-review__emoji">🖍️</p>
      <h2 data-i18n="hl.noneTitle">لا يوجد تظليل بعد</h2>
      <p class="dp-review__hint" data-i18n="hl.noneBody">
        افتح أي صفحة، وحدِّد جملة لفتت انتباهك، واختر لونًا. ستظهر هنا مرتبطةً مباشرةً بموضعها.
      </p>
      <a class="dp-btn dp-btn--primary" href="/" data-i18n="hl.browse">تصفّح المسارات ←</a>
    </div>

    <div data-dp-highlights-list></div>
  </div>
</BaseLayout>
