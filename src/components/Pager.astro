---
import { getCollection } from 'astro:content';
const { slug, collection = 'qiraa', base = '/qiraa' } = Astro.props as {
  slug: string;
  collection?: 'qiraa' | 'nahw' | 'sarf' | 'balagha' | 'tajwid' | 'khat' | 'quranArabic';
  base?: string;
};
const all = (await getCollection(collection)).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((p) => p.id === slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;
---
<nav class="dp-pager" aria-label="تنقّل الأقسام">
  {prev ? (
    <a class="prev" href={`${base}/${prev.id}/`}>
      <small>
        <span data-lang-block="ar">السابق <bdi>→</bdi></span>
        <span data-lang-block="en"><bdi>←</bdi> <span data-i18n="pager.prev">Previous</span></span>
      </small>
      <strong>
        <span data-lang-block="ar">{prev.data.title}</span>
        <span data-lang-block="en">{prev.data.title_en ?? prev.data.title}</span>
      </strong>
    </a>
  ) : <span></span>}
  {next ? (
    <a class="next" href={`${base}/${next.id}/`}>
      <small>
        <span data-lang-block="ar"><bdi>←</bdi> التالي</span>
        <span data-lang-block="en"><span data-i18n="pager.next">Next</span> <bdi>→</bdi></span>
      </small>
      <strong>
        <span data-lang-block="ar">{next.data.title}</span>
        <span data-lang-block="en">{next.data.title_en ?? next.data.title}</span>
      </strong>
    </a>
  ) : <span></span>}
</nav>
