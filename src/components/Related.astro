---
import { getCollection } from 'astro:content';
const { related, collection = 'qiraa', base = '/qiraa', heading = 'دروس ذات صلة', heading_en = 'Related lessons' } = Astro.props as {
  related: string[];
  collection?: 'qiraa' | 'nahw' | 'sarf' | 'balagha' | 'tajwid' | 'khat' | 'quranArabic';
  base?: string;
  heading?: string;
  heading_en?: string;
};
const all = await getCollection(collection);
const items = (related ?? [])
  .map((slug) => all.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---
{items.length > 0 && (
  <Fragment>
    <h2 id="related">
      <span data-lang-block="ar">{heading}</span>
      <span data-lang-block="en" data-i18n="related.heading">{heading_en}</span>
    </h2>
    <div class="dp-grid">
      {items.map((p) => (
        <a class="dp-card" data-cat={p.data.category} data-slug={p.id} href={`${base}/${p.id}/`}>
          <span class="dp-card__num">{p.data.category}</span>
          <span class="dp-card__title">{p.data.title}</span>
          <p class="dp-card__intent">{p.data.intent}</p>
        </a>
      ))}
    </div>
  </Fragment>
)}
