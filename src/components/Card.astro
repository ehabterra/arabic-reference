---
interface Props {
  slug: string;
  category: string;
  title: string;
  title_en?: string;
  intent: string;
  intent_en?: string;
  order?: number;
  difficulty?: string;
  status?: string;
  numLabel?: string;
  footLabel?: string;
  base?: string;
  minutes?: number;
}
const { slug, category, title, title_en, intent, intent_en, order, difficulty, status, numLabel, footLabel, base = '/patterns', minutes } = Astro.props;
---
<a class="dp-card" data-cat={category} data-slug={slug} href={`${base}/${slug}/`}>
  <span class="dp-card__num">{numLabel ?? `${order} · ${difficulty}`}</span>
  <span class="dp-card__title">
    <span data-lang-block="ar">{title}</span>
    <span data-lang-block="en">{title_en ?? title}</span>
  </span>
  <p class="dp-card__intent">
    <span data-lang-block="ar">{intent}</span>
    <span data-lang-block="en">{intent_en ?? intent}</span>
  </p>
  <span class="dp-card__foot">
    <span>
      {footLabel ?? (
      <>
        <span data-lang-block="ar">{status === 'ready' ? '✦ مكتمل' : 'مسودة'}</span>
        <span data-lang-block="en">{status === 'ready' ? '✦ Complete' : 'Draft'}</span>
      </>
    )}
      {minutes && <span class="dp-card__time">· ⏱ {minutes} <span data-lang-block="ar">د</span><span data-lang-block="en">m</span></span>}
    </span>
    <span class="dp-card__check" aria-hidden="true">✓</span>
  </span>
</a>
