---
interface QuizOption { text: string; text_en?: string; correct: boolean; }
interface QuizItem { q: string; q_en?: string; options: QuizOption[]; explain?: string; explain_en?: string; }
const { quiz } = Astro.props as { quiz: QuizItem[] };
---
<div class="dp-quiz" data-dp-quiz>
  <div class="dp-quiz__head">
    <h2 id="quiz">
      <span data-lang-block="ar">اختبر فهمك</span>
      <span data-lang-block="en" data-i18n="quiz.title">Test your understanding</span>
    </h2>
    <span class="dp-quiz__score" data-dp-score>
      <span data-lang-block="ar">النتيجة: 0 / {quiz.length}</span>
      <span data-lang-block="en">Score: 0 / {quiz.length}</span>
    </span>
  </div>
  {quiz.map((q, i) => (
    <div class="dp-q">
      <p class="dp-q__prompt">
        {i + 1}.
        <span data-lang-block="ar">{q.q}</span>
        <span data-lang-block="en">{q.q_en ?? q.q}</span>
      </p>
      {q.options.map((o) => (
        <button class="dp-opt" data-correct={o.correct ? 'true' : 'false'}>
          <span data-lang-block="ar">{o.text}</span>
          <span data-lang-block="en">{o.text_en ?? o.text}</span>
        </button>
      ))}
      {(q.explain || q.explain_en) && (
        <p class="dp-q__explain">
          <span data-lang-block="ar">{q.explain}</span>
          <span data-lang-block="en">{q.explain_en ?? q.explain}</span>
        </p>
      )}
    </div>
  ))}
</div>
