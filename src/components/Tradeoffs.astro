---
const { data: d } = Astro.props;
const show = (d.when_use?.length ?? 0) > 0 || (d.when_avoid?.length ?? 0) > 0;
---
{show && (
  <Fragment>
    <h2 id="when-to-use">
      <span data-lang-block="ar">متى تستخدمه — ومتى تتجنّبه</span>
      <span data-lang-block="en">When to use it — and when not</span>
    </h2>
    <div class="dp-tradeoffs">
      <div class="dp-tradeoffs__col dp-tradeoffs__col--use">
        <h4>
          <span data-lang-block="ar">✅ استخدمه حين</span>
          <span data-lang-block="en">✅ Reach for it when</span>
        </h4>
        <ul>{d.when_use.map((i: string) => <li>{i}</li>)}</ul>
      </div>
      <div class="dp-tradeoffs__col dp-tradeoffs__col--avoid">
        <h4>
          <span data-lang-block="ar">⛔ تأمَّل قبل الاستخدام حين</span>
          <span data-lang-block="en">⛔ Think twice when</span>
        </h4>
        <ul>{d.when_avoid.map((i: string) => <li>{i}</li>)}</ul>
      </div>
    </div>
  </Fragment>
)}
