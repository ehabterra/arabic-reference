---
const { data: d, slug, topicLabel = 'Concurrency', minutes } = Astro.props;
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const catLabel = cap(d.category.replace(/-/g, ' '));
const eyebrow =
  d.kind === 'guide'
    ? `${catLabel} · Guide`
    : d.kind === 'topic'
      ? `${catLabel} · ${topicLabel}`
      : `${catLabel} pattern${d.gof ? ' · Gang of Four' : ''}`;
---
<header class="dp-hero">
  <p class="dp-hero__eyebrow">{eyebrow}{d.difficulty ? ` · ${d.difficulty}` : ''}</p>
  <h1><span data-lang-block="ar">{d.title}</span><span data-lang-block="en">{d.title_en ?? d.title}</span></h1>
  {d.intent && <p class="dp-hero__lede" data-i18n-html={`intent.${slug}`}>{d.intent}</p>}
  {d.aka && (
    <p class="dp-kicker" style="margin-top:.9rem">
      <span data-lang-block="ar">يُعرف أيضاً بـ — {d.aka}</span>
      <span data-lang-block="en"><span data-i18n="pageheader.aka">Also known as —</span> {d.aka}</span>
    </p>
  )}
  <div class="dp-badges" style="margin-top:1.1rem">
    <span class="dp-badge" data-cat={d.category}><span class="dp-dot"></span>{catLabel}</span>
    {d.difficulty && <span class="dp-badge dp-badge--muted">{d.difficulty}</span>}
    {minutes && (
      <span class="dp-badge dp-badge--muted">
        ⏱ {minutes}
        <span data-lang-block="ar"> دقيقة قراءة</span>
        <span data-lang-block="en"> <span data-i18n="pageheader.minutesRead">min read</span></span>
      </span>
    )}
    <span class="dp-badge dp-badge--muted">
      <span data-lang-block="ar">{d.status === 'ready' ? 'مكتمل' : 'مسودة — المزيد قادم'}</span>
      <span data-lang-block="en">{d.status === 'ready' ? <span data-i18n="pageheader.ready">Complete</span> : <span data-i18n="pageheader.draft">Draft — more coming</span>}</span>
    </span>
  </div>
  {(d.source || d.playground) && (
    <div class="dp-hero__cta">
      {d.playground && (
        <a class="dp-btn dp-btn--primary" href={d.playground} target="_blank" rel="noopener" data-i18n="pageheader.playground">▶ تشغيل في Go Playground</a>
      )}
      {d.source && (
        <a class="dp-btn dp-btn--ghost" href={d.source} target="_blank" rel="noopener" data-i18n="pageheader.source">⌨ عرض المصدر</a>
      )}
    </div>
  )}
</header>
