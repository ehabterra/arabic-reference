---
// Native comments backed by Cloudflare D1 (see src/pages/api/comments.ts),
// gated behind Google Sign-In — no GitHub, no anonymous posts. The OAuth
// client id is read from PUBLIC_GOOGLE_CLIENT_ID; if it's unset the section
// shows a friendly "not configured yet" notice instead of breaking.
const clientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
---
<section class="dp-comments" id="dp-comments">
  <h2 class="dp-comments__title" data-i18n="comments.title">التعليقات</h2>

  {clientId ? (
    <>
      <p class="dp-comments__hint" id="dp-cmt-hint" data-i18n="comments.hint">سجّل الدخول بحساب Google للمشاركة في النقاش.</p>
      <div class="dp-cmt-auth" id="dp-cmt-auth"></div>
      <form class="dp-cmt-form" id="dp-cmt-form" hidden>
        <textarea
          class="dp-cmt-input"
          id="dp-cmt-text"
          rows="3"
          maxlength="2000"
          required
          placeholder="شارك بتعليقك أو سؤالك…"></textarea>
        <button type="submit" class="dp-cmt-submit" data-i18n="comments.submit">نشر التعليق</button>
      </form>
      <p class="dp-cmt-privacy" data-i18n-html="comments.privacy">بنشر تعليقك يُحفَظ اسمك وصورتك ومعرّف حساب Google فقط — <strong>دون بريدك الإلكتروني</strong>. ويمكنك حذف تعليقك في أي وقت.</p>
      <ul class="dp-cmt-list" id="dp-cmt-list" aria-live="polite"></ul>
    </>
  ) : (
    <p class="dp-comments__hint" data-i18n-html="comments.notConfigured">
      التعليقات غير مُفعَّلة بعد — يلزم ضبط <code>PUBLIC_GOOGLE_CLIENT_ID</code>.
    </p>
  )}
</section>

{clientId && (
  <>
    <script is:inline src="https://accounts.google.com/gsi/client" async></script>
    <script is:inline define:vars={{ clientId }}>
      (function () {
        const slug = location.pathname;
        const listEl = document.getElementById('dp-cmt-list');
        const form = document.getElementById('dp-cmt-form');
        const hint = document.getElementById('dp-cmt-hint');
        const authEl = document.getElementById('dp-cmt-auth');
        let mySub = null;
        let signedIn = false;

        const esc = (s) => {
          const d = document.createElement('div');
          d.textContent = s == null ? '' : String(s);
          return d.innerHTML;
        };
        const fmt = (iso) => {
          try { return new Date((iso || '').replace(' ', 'T') + 'Z').toLocaleDateString('ar'); }
          catch { return esc(iso); }
        };

        async function load() {
          if (!listEl) return;
          try {
            const r = await fetch('/api/comments?slug=' + encodeURIComponent(slug));
            const data = await r.json();
            const items = (data && data.comments) || [];
            listEl.innerHTML = items.length
              ? items.map((c) =>
                  '<li class="dp-cmt">' +
                  (c.picture ? '<img class="dp-cmt__av" src="' + esc(c.picture) + '" alt="" referrerpolicy="no-referrer" />' : '<span class="dp-cmt__av dp-cmt__av--none"></span>') +
                  '<div class="dp-cmt__main"><div class="dp-cmt__head"><span class="dp-cmt__name">' + esc(c.name) + '</span><time class="dp-cmt__time">' + fmt(c.created_at) + '</time>' +
                  ((mySub && c.user_sub === mySub) ? '<button class="dp-cmt__del" data-del="' + c.id + '">حذف</button>' : '') +
                  '</div>' +
                  '<p class="dp-cmt__text">' + esc(c.body) + '</p></div></li>'
                ).join('')
              : '<li class="dp-cmt-empty">لا توجد تعليقات بعد. كن أوّل المشاركين.</li>';
          } catch (e) { /* leave list as-is */ }
        }

        function renderSignedIn(name, picture) {
          if (!authEl) return;
          authEl.innerHTML =
            '<div class="dp-cmt-me">' +
            (picture ? '<img class="dp-cmt__av" src="' + esc(picture) + '" alt="" referrerpolicy="no-referrer" />' : '') +
            '<span>مسجَّل الدخول: <strong>' + esc(name) + '</strong></span>' +
            '<button type="button" class="dp-cmt-signout" id="dp-cmt-signout">تسجيل الخروج</button></div>';
          const so = document.getElementById('dp-cmt-signout');
          if (so) so.addEventListener('click', signOut);
          if (form) form.hidden = false;
          if (hint) hint.hidden = true;
        }

        function renderButton() {
          if (!(window.google && google.accounts && google.accounts.id) || !authEl) return;
          authEl.innerHTML = '';
          google.accounts.id.renderButton(authEl, { theme: 'outline', size: 'large', text: 'signin_with', shape: 'pill', locale: 'ar' });
        }

        // Ask our own session endpoint who we are — this is what survives refreshes.
        async function refreshSession() {
          try {
            const r = await fetch('/api/auth');
            const d = await r.json();
            if (d && d.user) {
              signedIn = true; mySub = d.user.sub || null;
              renderSignedIn(d.user.name || 'مستخدم', d.user.picture);
              return true;
            }
          } catch (e) { /* ignore */ }
          signedIn = false; mySub = null;
          return false;
        }

        async function signOut() {
          try { await fetch('/api/auth', { method: 'DELETE' }); } catch (e) {}
          try { google.accounts.id.disableAutoSelect(); } catch (e) {}
          signedIn = false; mySub = null;
          if (form) form.hidden = true;
          if (hint) { hint.hidden = false; hint.textContent = 'سجّل الدخول بحساب Google للمشاركة في النقاش.'; }
          renderButton();
          load();
        }

        // Google gives a one-time token; exchange it ONCE for a first-party session cookie.
        window.__dpCmtCredential = async function (resp) {
          const credential = resp && resp.credential;
          if (!credential) return;
          try {
            const r = await fetch('/api/auth', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ credential }),
            });
            if (r.ok) { await refreshSession(); await load(); }
          } catch (e) { /* ignore */ }
        };

        function initGSI() {
          if (!(window.google && google.accounts && google.accounts.id)) {
            return setTimeout(initGSI, 300);
          }
          google.accounts.id.initialize({ client_id: clientId, callback: window.__dpCmtCredential, auto_select: true });
          if (!signedIn) { renderButton(); google.accounts.id.prompt(); }
        }

        // Boot: trust our session cookie first (no Google round-trip on refresh);
        // only fall back to the Google button if there's no valid session.
        refreshSession().then((ok) => { if (!ok) initGSI(); load(); });

        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const ta = document.getElementById('dp-cmt-text');
            const body = (ta.value || '').trim();
            if (!body) return;
            const btn = form.querySelector('.dp-cmt-submit');
            btn.disabled = true;
            try {
              const r = await fetch('/api/comments', {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ slug, body }),
              });
              if (r.ok) { ta.value = ''; await load(); }
              else { const er = await r.json().catch(() => ({})); alert(er.error || 'تعذّر نشر التعليق.'); }
            } finally { btn.disabled = false; }
          });
        }

        if (listEl) {
          listEl.addEventListener('click', async (e) => {
            const b = e.target.closest('[data-del]');
            if (!b) return;
            if (!confirm('حذف تعليقك؟ لا يمكن التراجع.')) return;
            try {
              const r = await fetch('/api/comments', {
                method: 'DELETE',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ id: Number(b.getAttribute('data-del')) }),
              });
              if (r.ok) await load();
            } catch (e) { /* ignore */ }
          });
        }
      })();
    </script>
  </>
)}
