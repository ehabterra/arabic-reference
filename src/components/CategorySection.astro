---
import { getCollection } from 'astro:content';
import Card from './Card.astro';
import { readingTime } from '../lib/reading-time';

interface Props {
  cat: string;
  title: string;
  title_en?: string;
  blurb: string;
  blurb_en?: string;
  collection?: 'qiraa' | 'nahw' | 'sarf' | 'balagha' | 'tajwid' | 'khat' | 'quranArabic';
  base?: string;
}
const { cat, title, title_en, blurb, blurb_en, collection = 'qiraa', base = '/qiraa' } = Astro.props;

const all = await getCollection(collection);
const items = all
  .filter((p) => p.data.category === cat)
  .sort((a, b) => a.data.order - b.data.order);
const slugs = items.map((p) => p.id).join(',');
---
<section class="dp-cat" id={cat}>
  <div class="dp-section-head">
    <h2><span class="dp-badge" data-cat={cat}><span class="dp-dot"></span>
      <span data-lang-block="ar">{title}</span>
      <span data-lang-block="en">{title_en ?? title}</span>
    </span></h2>
    <p>
      <span data-lang-block="ar">{blurb}</span>
      <span data-lang-block="en">{blurb_en ?? blurb}</span>
    </p>
    {items.length > 0 && (
      <div class="dp-progress" data-dp-progress data-slugs={slugs} style="margin-top:.9rem;max-width:440px;">
        <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
        <span class="dp-progress__label"></span>
      </div>
    )}
  </div>
  {items.length === 0 ? (
    <p class="dp-kicker" style="margin-top:-.4rem;" data-i18n="cat.soon">🚧 Coming soon.</p>
  ) : (
    <div class="dp-grid">
      {items.map((p) => (
        <Card
          slug={p.id}
          category={p.data.category}
          title={p.data.title}
          title_en={p.data.title_en}
          intent={p.data.intent}
          order={p.data.order}
          difficulty={p.data.difficulty}
          status={p.data.status}
          base={base}
          minutes={readingTime(p.body)}
        />
      ))}
    </div>
  )}
</section>
